import java.util.*;
public class Main
{
	public static void main(String[] args) {
	    int a[] = {1,2,3,4,6};
	    int b[] = {7,8,9,10};
	    Scanner sc = new Scanner(System.in);
	    int c[] = new int[a.length+b.length];
	    for(int i=0;i<(a.length);i++){
	        c[i]=a[i];
	    }
	    for(int i=0;i<(b.length);i++){
	        c[a.length+i]=b[i];
	    }
	    for(int nums : c){
	        System.out.print(nums +" ");
	    }
		
	}
}
